---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import CourseReviews from '@/components/CourseReviews';

const { code } = Astro.params;
if (!code) return Astro.redirect('/');

const entries = await getCollection('courses');
const entry = entries.find((e) => e.data.course_code.value === code);
if (!entry) return Astro.redirect('/');

const d = entry.data;
const c = {
  code: d.course_code.value,
  title: d.course_title.value,
  level: d.academic_level.value,
  credits: d.credits.value,
  description: d.short_description_of_the_course.value,
  typicallyOffered: d.typically_offered.value,
  timetable: d.timetable_and_length_and_frequency_of_teaching_sessions.value,
  aims: d.course_aims.value,
  outcomes: d.intended_learning_outcomes_of_course.value,
  categories: d.categories.value,
  requirements: (d.requirements_of_entry.value as (string | null)[]).filter(Boolean) as string[],
  coRequisites: d.co_requisites.value,
  excludedCourses: d.excluded_courses.value,
  assessment: d.summative_assessment_methods.value,
  assessmentDescription: d.description_of_summative_assessment.value,
  examinationDiet: d.examination_diet.value,
  examDuration: d.total_exam_duration.value,
  additionalInfo: d.additional_relevant_information.value,
};

const assessmentPalette = ['#4f46e5', '#0891b2', '#059669', '#d97706'];
const assessmentItems = c.assessment.rows.filter(row => row.percentage > 0).sort((a, b) => b.percentage - a.percentage).map((row: { method: string; percentage: number }) => ({
  label: row.method,
  pct: row.percentage,
}));

function prose(text: string) {
  return text.split('\n').filter((l) => l.trim());
}
---

<Layout>
  <div class="min-h-screen bg-page text-ink">
    <div class="sticky top-0 z-10 border-b border-border bg-panel px-6 py-3">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-accent hover:underline underline-offset-2"
      >
        ← Course catalogue
      </a>
    </div>

    <div class="mx-auto max-w-4xl px-6 py-8 sm:px-8">
      <!-- Header -->
      <header class="mb-8">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="font-mono text-sm text-accent">{c.code}</span>
          <span
            class={`rounded-full border border-border px-2.5 py-0.5 text-xs text-ink-muted ${c.credits === 20 ? 'bg-badge' : 'bg-white'}`}
          >
            {c.credits} credits
          </span>
          <span class="rounded-full border border-border bg-white px-2.5 py-0.5 text-xs text-ink-muted">
            {c.typicallyOffered}
          </span>
        </div>
        <h1 class="mb-1 text-2xl font-bold">{c.title}</h1>
        <p class="mb-3 text-sm text-ink-muted">{c.level}</p>
        <div class="flex flex-wrap gap-1.5">
          {c.categories.map((cat) => (
            <span class="rounded-full bg-panel px-2.5 py-0.5 text-xs text-ink-muted">
              {cat}
            </span>
          ))}
        </div>
      </header>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
        <!-- Main column -->
        <div class="lg:col-span-2 flex flex-col gap-7">
          <!-- Description -->
          <section>
            <h2 class="mb-2 text-sm font-semibold uppercase text-ink-muted">Description</h2>
            {prose(c.description).map((line) => (
              <p class="mb-2 text-sm leading-relaxed text-ink-secondary">{line}</p>
            ))}
          </section>

          <!-- Aims -->
          <section>
            <h2 class="mb-2 text-sm font-semibold uppercase text-ink-muted">Course aims</h2>
            {prose(c.aims).map((line) => (
              <p class="mb-2 text-sm leading-relaxed text-ink-secondary">{line}</p>
            ))}
          </section>

          <!-- Outcomes -->
          <section>
            <h2 class="mb-2 text-sm font-semibold uppercase text-ink-muted">Learning outcomes</h2>
            {prose(c.outcomes).map((line) => (
              <p class="mb-2 text-sm leading-relaxed text-ink-secondary">{line}</p>
            ))}
          </section>

          <!-- Assessment -->
          <section>
            <h2 class="mb-3 text-sm font-semibold uppercase text-ink-muted">Assessment</h2>
            <div class="pb-4 mb-4 flex flex-col gap-2.5 border-b border-border">
              <div class="flex h-3.5 overflow-hidden rounded border border-border">
                {assessmentItems.map((it, i) => (
                  <div
                    title={`${it.label} — ${it.pct}%`}
                    style={`width:${it.pct}%;background:${assessmentPalette[i % assessmentPalette.length]}`}
                  />
                ))}
              </div>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                {assessmentItems.map((it, i) => (
                  <span class="flex items-center gap-1.75 text-[13px] text-ink-secondary">
                    <span
                      class="inline-block h-2.5 w-2.5 shrink-0 rounded-sm"
                      style={`background:${assessmentPalette[i % assessmentPalette.length]}`}
                    />
                    <span>{it.label}</span>
                    <span class="font-mono text-ink-muted">{it.pct}%</span>
                  </span>
                ))}
              </div>
            </div>
            {prose(c.assessmentDescription).map((line) => (
              <p class="mb-2 text-sm leading-relaxed text-ink-secondary">{line}</p>
            ))}
          </section>
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-4">
          <div class="rounded-lg border border-border bg-surface p-4">
            <h3 class="mb-3 text-xs font-semibold uppercase text-ink-muted">
              Course details
            </h3>
            <dl class="flex flex-col gap-2.5 text-sm">
              <div>
                <dt class="text-xs text-ink-subtle">Timetable</dt>
                <dd class="text-ink">{c.timetable}</dd>
              </div>
              {c.examinationDiet && (
                <div>
                  <dt class="text-xs text-ink-subtle">Exam diet</dt>
                  <dd class="text-ink">{c.examinationDiet}</dd>
                </div>
              )}
              {c.examDuration && parseInt(c.examDuration) > 0 && (
                <div>
                  <dt class="text-xs text-ink-subtle">Exam duration</dt>
                  <dd class="text-ink">{c.examDuration}</dd>
                </div>
              )}
            </dl>
          </div>

          {c.requirements.length > 0 && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <h3 class="mb-3 text-xs font-semibold uppercase text-ink-muted">
                Requirements of entry
              </h3>
              <ul class="flex flex-col gap-1.5">
                {c.requirements.map((req) => (
                  <li class="flex items-start gap-1.5 text-sm text-ink-secondary">
                    <span class="mt-0.5 text-accent shrink-0">·</span>
                    {req}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {(c.coRequisites || c.excludedCourses) && (
            <div class="rounded-lg border border-border bg-surface p-4 flex flex-col gap-2.5 text-sm">
              {c.coRequisites && (
                <div>
                  <dt class="text-xs text-ink-subtle">Co-requisites</dt>
                  <dd class="text-ink">{c.coRequisites}</dd>
                </div>
              )}
              {c.excludedCourses && (
                <div>
                  <dt class="text-xs text-ink-subtle">Excluded courses</dt>
                  <dd class="text-ink">{c.excludedCourses}</dd>
                </div>
              )}
            </div>
          )}

          {c.additionalInfo && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <h3 class="mb-2 text-xs font-semibold uppercase text-ink-muted">
                Additional info
              </h3>
              <p class="text-sm text-ink-secondary">{c.additionalInfo}</p>
            </div>
          )}
        </aside>
      </div>

      <!-- Reviews section -->
      <div class="mt-12 border-t border-border pt-8">
        <CourseReviews courseCode={c.code} client:load />
      </div>
    </div>
  </div>
</Layout>
